---
export interface Props {
    idPrefix?: string;
}

const { idPrefix = "byok-" } = Astro.props;
---

<div class="byok-form-container" style="text-align: left;">
    <div style="margin-bottom: var(--spacing-sm);">
        <label
            for={`${idPrefix}select-provider`}
            style="display: block; margin-bottom: 4px; font-size: 0.9rem;"
        >
            Provider
        </label>
        <select
            id={`${idPrefix}select-provider`}
            style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
        >
            <option value="google">Google (Gemini)</option>
            <option value="claude">Anthropic (Claude)</option>
            <option value="openai">OpenAI</option>
            <option value="openrouter">OpenRouter</option>
        </select>
    </div>

    <div style="margin-bottom: var(--spacing-sm);">
        <label
            for={`${idPrefix}input-api-key`}
            style="display: block; margin-bottom: 4px; font-size: 0.9rem;"
        >
            API Key
        </label>
        <input
            type="password"
            id={`${idPrefix}input-api-key`}
            placeholder="Provider API Key..."
            style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
        />
        <div
            id={`${idPrefix}api-key-help`}
            style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 4px;"
            class="hidden"
        >
            Leave blank to keep your existing key.
        </div>
    </div>

    <div style="margin-bottom: var(--spacing-md);">
        <label
            for={`${idPrefix}select-model`}
            style="display: block; margin-bottom: 4px; font-size: 0.9rem;"
        >
            Model
        </label>
        <select
            id={`${idPrefix}select-model`}
            disabled
            style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
        >
            <option value="">Enter API Key to load models...</option>
        </select>
    </div>

    <button
        id={`${idPrefix}btn-submit`}
        class="btn primary"
        style="width: 100%;"
    >
        Save Key
    </button>

    <div
        id={`${idPrefix}status-message`}
        style="margin-top: 8px; font-size: 0.85rem; text-align: center; color: var(--color-accent);"
        class="hidden"
    >
    </div>
</div>
