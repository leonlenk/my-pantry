---
import "../styles/global.scss";
import feather from "feather-icons";
const coffeeIcon = (
    feather.icons["coffee"] || feather.icons["help-circle"]
).toSvg({
    width: 48,
    height: 48,
    color: "var(--color-accent)",
});
const keyIcon = (feather.icons["key"] || feather.icons["help-circle"]).toSvg({
    width: 18,
    height: 18,
});
const downloadIcon = (
    feather.icons["download"] || feather.icons["help-circle"]
).toSvg({
    width: 48,
    height: 48,
    color: "var(--color-accent)",
});
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Pantry Clip - Setup</title>
        <style>
            body {
                display: flex;
                justify-content: center;
                align-items: center;
                min-height: 100vh;
                background-color: var(--color-surface);
            }
            .setup-card {
                max-width: 480px;
                width: 100%;
                text-align: center;
                padding: var(--spacing-xl);
            }
            .brand-title {
                font-family: var(--font-serif);
                color: var(--color-primary);
                font-size: 2.5rem;
                margin-bottom: var(--spacing-xs);
                letter-spacing: -0.02em;
            }
            .brand-subtitle {
                color: var(--color-text-muted);
                font-size: 1.1rem;
                margin-bottom: var(--spacing-xl);
            }

            .view-state {
                display: none;
                animation: fadeIn 0.3s ease-in-out;
            }

            .view-state.active {
                display: block;
            }

            @keyframes fadeIn {
                from {
                    opacity: 0;
                    transform: translateY(5px);
                }
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            .btn.google {
                width: 100%;
                padding: 12px;
                background: white;
                color: #444;
                border: 1px solid #ddd;
                font-size: 1rem;
                margin-bottom: var(--spacing-md);
            }

            .btn.google:hover {
                background: #f8f8f8;
            }

            .btn.google.loading {
                color: #888;
                cursor: not-allowed;
                opacity: 0.85;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
            }

            /* Inline spinner shown while the OAuth popup is opening */
            .btn-spinner {
                display: inline-block;
                width: 16px;
                height: 16px;
                border: 2px solid #ccc;
                border-top-color: #555;
                border-radius: 50%;
                animation: btn-spin 0.7s linear infinite;
                flex-shrink: 0;
            }

            @keyframes btn-spin {
                to {
                    transform: rotate(360deg);
                }
            }

            .btn.byok {
                width: 100%;
                padding: 12px;
                font-size: 1rem;
                border: 1px solid var(--color-accent);
            }

            .provider-divider {
                display: flex;
                align-items: center;
                text-align: center;
                margin: var(--spacing-md) 0;
                color: var(--color-text-meta);
            }

            .provider-divider::before,
            .provider-divider::after {
                content: "";
                flex: 1;
                border-bottom: 1px solid var(--color-border);
            }

            .provider-divider:not(:empty)::before {
                margin-right: 0.25em;
            }

            .provider-divider:not(:empty)::after {
                margin-left: 0.25em;
            }

            /* Progress Bar Styles */
            .progress-container {
                width: 100%;
                height: 8px;
                background-color: var(--color-border);
                border-radius: var(--radius-pill);
                overflow: hidden;
                margin: var(--spacing-md) 0;
            }

            .progress-fill {
                height: 100%;
                background-color: var(--color-accent);
                width: 0%;
                transition: width 0.2s ease-out;
            }
        </style>
    </head>
    <body>
        <main class="card setup-card">
            <h1 class="brand-title">Pantry Clip</h1>
            <p class="brand-subtitle">Your intelligent recipe vault</p>

            <!-- STATE 1: ONBOARDING / LOGIN -->
            <section id="step-login" class="view-state active">
                <p style="margin-bottom: var(--spacing-lg);">
                    Sign in to sync your recipes across devices, or provide your
                    own API key to run fully local.
                </p>

                <button id="btn-oauth-supabase" class="btn google">
                    <svg
                        style="margin-right: 8px; width:18px; height:18px;"
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M12.0001 2.05315C11.6663 2.05315 11.3418 2.15286 11.0772 2.33612L3.6369 7.49132C2.986 7.94226 2.6575 8.76159 2.80931 9.55397C2.96112 10.3464 3.56589 10.9678 4.33129 11.1179L10.0886 12.247L6.28974 15.6321C5.74834 16.1147 5.56459 16.8993 5.82393 17.6163C6.08328 18.3333 6.74108 18.8358 7.48792 18.8872L11.5303 19.1654C11.8596 19.1881 12.1864 19.0607 12.4283 18.8173C12.6702 18.574 12.7937 18.2435 12.7663 17.9103C12.7118 17.2458 12.1315 16.7469 11.4651 16.701L8.79442 16.5173L11.7779 13.8587C12.3168 13.3783 12.5029 12.597 12.2464 11.882C11.9899 11.1671 11.336 10.6651 10.5925 10.6121L5.9431 10.279L12.0001 6.0827L18.0571 10.279L13.4077 10.6121C12.6642 10.6651 12.0104 11.1671 11.7538 11.882C11.4973 12.597 11.6834 13.3783 12.2223 13.8587L15.2058 16.5173L12.5351 16.701C11.8687 16.7469 11.2884 17.2458 11.2339 17.9103C11.2065 18.2435 11.33 18.574 11.5719 18.8173C11.8138 19.0607 12.1406 19.1881 12.4699 19.1654L16.5123 18.8872C17.2591 18.8358 17.9169 18.3333 18.1763 17.6163C18.4356 16.8993 18.2519 16.1147 17.7105 15.6321L13.9116 12.247L19.669 11.1179C20.4343 10.9678 21.0391 10.3464 21.1909 9.55397C21.3427 8.76159 21.0142 7.94226 20.3633 7.49132L12.923 2.33612C12.6584 2.15286 12.3339 2.05315 12.0001 2.05315Z"
                            fill="#3ECF8E"></path>
                    </svg>
                    Continue with Supabase
                </button>

                <div class="provider-divider">OR</div>

                <button id="btn-show-byok" class="btn outline byok">
                    <span set:html={keyIcon}></span>

                    Bring Your Own Key
                </button>

                <div id="byok-form" class="hidden mt" style="text-align: left;">
                    <div style="margin-bottom: var(--spacing-sm);">
                        <label
                            for="select-provider"
                            style="display: block; margin-bottom: 4px; font-size: 0.9rem;"
                            >Provider</label
                        >
                        <select
                            id="select-provider"
                            style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
                        >
                            <option value="google">Google (Gemini)</option>
                            <option value="openai">OpenAI</option>
                            <option value="claude">Anthropic (Claude)</option>
                            <option value="openrouter">OpenRouter</option>
                        </select>
                    </div>

                    <div style="margin-bottom: var(--spacing-sm);">
                        <label
                            for="input-api-key"
                            style="display: block; margin-bottom: 4px; font-size: 0.9rem;"
                            >API Key</label
                        >
                        <input
                            type="password"
                            id="input-api-key"
                            placeholder="Provider API Key..."
                            style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
                        />
                    </div>

                    <div style="margin-bottom: var(--spacing-md);">
                        <label
                            for="select-model"
                            style="display: block; margin-bottom: 4px; font-size: 0.9rem;"
                            >Model</label
                        >
                        <select
                            id="select-model"
                            disabled
                            style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); background-color: var(--color-bg);"
                        >
                            <option value=""
                                >Enter API Key to load models...</option
                            >
                        </select>
                    </div>

                    <button
                        id="btn-submit-byok"
                        class="btn primary"
                        style="width: 100%;">Save Key</button
                    >
                </div>
            </section>

            <!-- STATE 2: DOWNLOADING AI MODEL -->
            <section id="step-downloading" class="view-state">
                <span
                    set:html={downloadIcon}
                    style="display:block;margin-bottom:1rem;"></span>

                <h2>Initializing Local AI...</h2>
                <p class="text-meta" style="margin-bottom: 2rem;">
                    Downloading the vectorization engine (~34MB). This only
                    happens once and ensures your data stays completely private.
                </p>

                <div class="progress-container">
                    <div id="progress-bar-fill" class="progress-fill"></div>
                </div>
                <p
                    id="progress-text"
                    style="font-size: 0.9rem; font-weight: 500;"
                >
                    0%
                </p>
            </section>

            <!-- STATE 3: POPULATING PANTRY (cold boot sync, Google OAuth only) -->
            <section id="step-syncing" class="view-state">
                <span
                    set:html={downloadIcon}
                    style="display:block;margin-bottom:1rem;"></span>
                <h2>Populating your Pantry...</h2>
                <p class="text-meta" style="margin-bottom: 2rem;">
                    Pulling your recipes from the cloud. Just a moment!
                </p>
                <div class="progress-container">
                    <div id="sync-bar-fill" class="progress-fill"></div>
                </div>
                <p id="sync-text" style="font-size: 0.9rem; font-weight: 500;">
                    Starting sync...
                </p>
            </section>

            <!-- STATE 3: READY -->
            <section id="step-ready" class="view-state">
                <span
                    set:html={coffeeIcon}
                    style="display:block;margin-bottom:1rem;"></span>

                <h2>You're all set!</h2>
                <p>
                    Pantry Clip is ready. You can now close this tab, pin the
                    extension to your toolbar, and start saving recipes!
                </p>
                <button id="btn-close-tab" class="btn outline mt"
                    >Close Tab</button
                >
            </section>
        </main>

        <script src="../utils/setup.ts"></script>
    </body>
</html>
