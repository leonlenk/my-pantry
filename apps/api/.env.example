SUPABASE_URL="your-supabase-project-url"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL=gemini-2.5-flash
EXTENSION_ID="your-chrome-extension-id"
MAX_PAYLOAD_CHARS=20000
EXTRACT_DAILY_LIMIT=15
EXTRACT_WEEKLY_LIMIT=50
SUBSTITUTE_DAILY_LIMIT=15
SUBSTITUTE_WEEKLY_LIMIT=50
SHARE_DAILY_LIMIT=100
SHARE_WEEKLY_LIMIT=500
CORS_ALLOW_LOCALHOST=false
SUPABASE_REQUEST_TIMEOUT=30
# Optional — override defaults if needed
PUBLIC_BASE_URL=https://mypantry.dev
SHARE_EXPIRY_DAYS=30
JWT_AUDIENCE=authenticated
SUPABASE_PUB_KEY_PATH=supabase_pub_key.json

