---
import "../styles/global.scss";
import "../styles/pantry.scss";
import Sidebar from "../components/pantry/Sidebar.astro";
import TopBar from "../components/pantry/TopBar.astro";
import RecipeGrid from "../components/pantry/RecipeGrid.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recipe AI - Pantry Dashboard</title>
  </head>
  <body>
    <div class="pantry-layout">
      <Sidebar />

      <main class="content">
        <TopBar />
        <RecipeGrid />
      </main>
    </div>

    <script>
      import { getAllRecipes, deleteRecipe, searchRecipes } from "../utils/db";
      import type { Recipe } from "../types/recipe";

      declare const chrome: any;

      const grid = document.getElementById("recipe-grid");
      const emptyState = document.getElementById("empty-state");
      const searchInput = document.getElementById(
        "semantic-search"
      ) as HTMLInputElement;
      const searchBtn = document.getElementById(
        "search-btn"
      ) as HTMLButtonElement;
      const recipeCountEl = document.getElementById("recipe-count");

      document.addEventListener("DOMContentLoaded", async () => {
        // Redirect to setup if not configured
        if (
          typeof chrome !== "undefined" &&
          chrome.storage &&
          chrome.storage.local
        ) {
          const { setupComplete } = await chrome.storage.local.get([
            "setupComplete",
          ]);
          if (!setupComplete) {
            window.location.href = "setup.html";
            return;
          }
        }

        await loadRecipes();
      });

      async function loadRecipes() {
        const recipes = await getAllRecipes();
        if (recipeCountEl)
          recipeCountEl.textContent = `${recipes.length} recipe${
            recipes.length !== 1 ? "s" : ""
          }`;
        renderRecipes(recipes);
      }

      function renderRecipes(recipes: Recipe[]) {
        if (!grid || !emptyState) return;
        grid.innerHTML = "";

        if (recipes.length === 0) {
          grid.classList.add("hidden");
          emptyState.classList.remove("hidden");
          return;
        }

        grid.classList.remove("hidden");
        emptyState.classList.add("hidden");

        recipes.forEach((recipe: Recipe, index: number) => {
          const card = document.createElement("div");
          card.className = "card recipe-card";
          card.style.animationDelay = `${index * 0.05}s`;

          const tagsHtml = recipe.tags
            ? recipe.tags
                .map((tag) => `<span class="tag">${tag}</span>`)
                .join("")
            : "";

          const metaHtml = [
            recipe.totalTimeMinutes ? `⏱ ${recipe.totalTimeMinutes}m` : null,
            recipe.servings ? `🍽 ${recipe.servings} servings` : null,
            recipe.yield ? `📦 ${recipe.yield}` : null,
          ]
            .filter(Boolean)
            .join(" &nbsp;·&nbsp; ");

          const description = (recipe.description || "").slice(0, 140);

          card.innerHTML = `
          <div class="card-header">
            <h3>${recipe.title}</h3>
            <button class="delete-btn" data-id="${
              recipe.id
            }" title="Delete recipe">✕</button>
          </div>
          ${metaHtml ? `<p class="meta">${metaHtml}</p>` : ""}
          <p class="desc">${description}${
            (recipe.description || "").length > 140 ? "..." : ""
          }</p>
          <div class="tags">${tagsHtml}</div>
          <div class="card-footer">
            ${
              recipe.url
                ? `<a href="${recipe.url}" target="_blank" class="view-btn">View Source →</a>`
                : "<span></span>"
            }
          </div>
        `;

          card
            .querySelector(".delete-btn")
            ?.addEventListener("click", async (e) => {
              e.stopPropagation();
              const id = (e.currentTarget as HTMLButtonElement).dataset.id!;
              await deleteRecipe(id);
              card.remove();
              const remaining = grid.querySelectorAll(".recipe-card").length;
              if (recipeCountEl)
                recipeCountEl.textContent = `${remaining} recipe${
                  remaining !== 1 ? "s" : ""
                }`;
              if (remaining === 0) {
                grid.classList.add("hidden");
                emptyState.classList.remove("hidden");
              }
            });

          grid.appendChild(card);
        });
      }

      async function handleSearch() {
        const query = searchInput.value.trim();
        if (!query) {
          await loadRecipes();
          return;
        }

        searchBtn.disabled = true;
        searchBtn.textContent = "Searching...";

        try {
          // Ask the background script to generate an embedding using the offscreen document
          const result: {
            success: boolean;
            embedding?: number[];
            error?: string;
          } = await chrome.runtime.sendMessage({
            type: "GENERATE_EMBEDDING",
            text: query,
          });

          if (result.success && result.embedding) {
            const matches = await searchRecipes(result.embedding, 20);
            renderRecipes(matches);
            if (recipeCountEl)
              recipeCountEl.textContent = `${matches.length} result${
                matches.length !== 1 ? "s" : ""
              } for "${query}"`;
          } else {
            console.error("Search embedding failed:", result.error);
            // Fall back to simple text search across title and tags
            const all = await getAllRecipes();
            const lower = query.toLowerCase();
            const filtered = all.filter(
              (r) =>
                r.title?.toLowerCase().includes(lower) ||
                r.tags?.some((t) => t.toLowerCase().includes(lower))
            );
            renderRecipes(filtered);
          }
        } catch (err) {
          console.error("Search error:", err);
        } finally {
          searchBtn.disabled = false;
          searchBtn.textContent = "Search";
        }
      }

      searchBtn?.addEventListener("click", handleSearch);

      searchInput?.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "Enter") handleSearch();
      });

      // Reset to all recipes when search is cleared
      searchInput?.addEventListener("input", async () => {
        if (searchInput.value === "") await loadRecipes();
      });
    </script>
  </body>
</html>
