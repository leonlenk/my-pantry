---
import "../styles/global.scss";
import "../styles/popup.scss";
import MainView from "../components/popup/MainView.astro";
import SetupView from "../components/popup/SetupView.astro";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recipe AI - Action Panel</title>
  </head>
  <body>
    <MainView />
    <SetupView />

    <script>
      import { decryptData, encryptData } from "../utils/crypto";
      import {
        checkJsonLd,
        extractWithReadability,
        extractRecipeWithClaude,
      } from "../utils/parser";
      import { saveRecipeLocally } from "../utils/db";

      // ------------- View State -------------
      const mainView = document.getElementById("main-view");
      const setupView = document.getElementById("setup-view");
      const settingsBtn = document.getElementById("settings-btn");
      const closeSettingsBtn = document.getElementById("close-settings-btn");

      function showSetup() {
        mainView?.classList.add("hidden");
        setupView?.classList.remove("hidden");
      }

      function showMain() {
        setupView?.classList.add("hidden");
        mainView?.classList.remove("hidden");
      }

      settingsBtn?.addEventListener("click", showSetup);
      closeSettingsBtn?.addEventListener("click", showMain);

      // Check storage on load to auto-show setup if no key config exists
      document.addEventListener("DOMContentLoaded", async () => {
        try {
          if (typeof chrome !== "undefined" && chrome.storage) {
            const data = await chrome.storage.local.get([
              "plaintextApiKey",
              "encryptedApiKey",
            ]);

            if (!data.plaintextApiKey && !data.encryptedApiKey) {
              showSetup();
            }
          }
        } catch (e) {
          console.warn("Storage check failed on load", e);
        }
      });

      // ------------- Main Panel API -------------
      const openPantryBtn = document.getElementById("open-pantry-btn");
      const extractBtn = document.getElementById("extract-btn");
      const passwordContainer = document.getElementById("password-container");
      const confirmExtractBtn = document.getElementById("confirm-extract-btn");
      const passwordInput = document.getElementById(
        "popup-password"
      ) as HTMLInputElement;
      const extractionStatus = document.getElementById("extraction-status");

      openPantryBtn?.addEventListener("click", () => {
        if (typeof chrome !== "undefined" && chrome.tabs) {
          chrome.tabs.create({ url: chrome.runtime.getURL("pantry.html") });
        } else {
          window.open("/pantry", "_blank");
        }
      });

      extractBtn?.addEventListener("click", async () => {
        if (extractBtn) {
          (extractBtn as HTMLButtonElement).disabled = true;
          extractBtn.textContent = "Loading...";
        }

        try {
          const storageResult: Record<string, any> =
            await chrome.storage.local.get([
              "plaintextApiKey",
              "llmModel",
              "llmProvider",
            ]);
          if (storageResult.plaintextApiKey) {
            const llmModel =
              storageResult.llmModel || "claude-3-5-sonnet-20241022";
            const llmProvider = storageResult.llmProvider || "anthropic";

            // Show status immediately since we bypassed the password button
            extractBtn?.classList.add("hidden");
            passwordContainer?.classList.remove("hidden");
            if (passwordInput) passwordInput.classList.add("hidden");
            if (confirmExtractBtn) confirmExtractBtn.classList.add("hidden");

            if (extractionStatus) {
              extractionStatus.classList.remove("hidden");
              extractionStatus.textContent = "Starting extraction...";
            }

            try {
              await executeExtraction(
                storageResult.plaintextApiKey as string,
                llmModel as string,
                llmProvider as string
              );
            } catch (err: any) {
              console.error("Extraction error", err);
              if (extractionStatus) {
                let msg = err.message || "Unknown error occurred";
                if (msg.length > 80) msg = msg.substring(0, 80) + "...";
                extractionStatus.textContent = `Error: ${msg}`;
              }
            }
            return;
          }
        } catch (e: any) {
          console.error("Storage error", e);
        }

        // Hide initial button and show password input
        extractBtn?.classList.add("hidden");
        passwordContainer?.classList.remove("hidden");
        passwordInput?.focus();
      });

      confirmExtractBtn?.addEventListener("click", async () => {
        const password = passwordInput?.value;
        if (!password) {
          if (extractionStatus)
            extractionStatus.textContent = "Please enter your password.";
          return;
        }

        if (confirmExtractBtn) {
          (confirmExtractBtn as HTMLButtonElement).disabled = true;
          confirmExtractBtn.textContent = "Loading...";
        }

        if (extractionStatus)
          extractionStatus.textContent = "Decrypting keys...";

        try {
          const storageResult: Record<string, any> =
            await chrome.storage.local.get([
              "encryptedApiKey",
              "llmModel",
              "llmProvider",
            ]);
          const encryptedApiKey = storageResult.encryptedApiKey;
          const llmModel =
            storageResult.llmModel || "claude-3-5-sonnet-20241022";
          const llmProvider = storageResult.llmProvider || "anthropic";

          if (!encryptedApiKey) {
            if (extractionStatus)
              extractionStatus.textContent =
                "No API key found. Please run setup again.";
            if (confirmExtractBtn) {
              (confirmExtractBtn as HTMLButtonElement).disabled = false;
              confirmExtractBtn.textContent = "Confirm Extraction";
            }
            return;
          }

          const apiKey = await decryptData(encryptedApiKey, password);
          await executeExtraction(apiKey, llmModel, llmProvider);
        } catch (error: any) {
          console.error(error);
          if (extractionStatus) {
            let msg = error.message || "Unknown error";
            if (msg.length > 80) msg = msg.substring(0, 80) + "...";
            extractionStatus.textContent = `Error: ${msg}`;
          }
        } finally {
          if (
            confirmExtractBtn &&
            extractionStatus &&
            !extractionStatus.textContent?.includes("successfully")
          ) {
            // Only revert button if we didn't succeed, so they can try again if they want
            (confirmExtractBtn as HTMLButtonElement).disabled = false;
            confirmExtractBtn.textContent = "Confirm Extraction";
          }
        }
      });

      async function executeExtraction(
        apiKey: string,
        llmModel: string,
        llmProvider: string
      ) {
        console.log(
          `[Recipe AI] Starting extraction with ${llmProvider} model: ${llmModel}`
        );
        if (extractionStatus) {
          extractionStatus.classList.remove("hidden");
          extractionStatus.textContent = "Extracting page content...";
        }

        const [tab] = await chrome.tabs.query({
          active: true,
          currentWindow: true,
        });

        if (!tab || !tab.id) {
          if (extractionStatus)
            extractionStatus.textContent = "Could not find active tab.";
          return;
        }

        console.log(`[Recipe AI] Found active tab: ${tab.url}`);

        console.log("[Recipe AI] Checking for JSON-LD schema...");
        let results = await chrome.scripting.executeScript({
          target: { tabId: tab.id },
          func: checkJsonLd,
        });

        let extractedData = results?.[0]?.result;

        if (!extractedData) {
          console.log(
            "[Recipe AI] No JSON-LD found. Injecting Readability fallback..."
          );
          if (extractionStatus)
            extractionStatus.textContent = "Loading Readability fallback...";

          await chrome.scripting.executeScript({
            target: { tabId: tab.id },
            files: ["Readability.js"],
          });

          console.log("[Recipe AI] Executing Readability extraction...");
          results = await chrome.scripting.executeScript({
            target: { tabId: tab.id },
            func: extractWithReadability,
          });

          extractedData = results?.[0]?.result;
        }

        if (!extractedData) {
          console.error("[Recipe AI] Extraction failed: No results returned.");
          if (extractionStatus)
            extractionStatus.textContent = "Extraction failed on this page.";
          return;
        }

        // Branch on extraction source for logging and user-facing status.
        if (extractedData.source === "json-ld") {
          console.log(
            "[Recipe AI] JSON-LD schema found, skipping Readability."
          );
          if (extractionStatus)
            extractionStatus.textContent =
              "Analyzing structured recipe data...";
        } else {
          console.log(
            "[Recipe AI] No JSON-LD found, using Readability fallback.",
            `Text length: ${extractedData.textContent?.length ?? 0} chars.`
          );
          if (extractionStatus)
            extractionStatus.textContent = "Sending to LLM for analysis...";
        }

        console.log("[Recipe AI] Sending request to LLM API...");
        const recipeData = await extractRecipeWithClaude(
          extractedData,
          apiKey,
          llmModel,
          llmProvider
        );

        console.log("Successfully parsed recipe:", recipeData);

        // Generate a vector embedding via the hidden offscreen document
        if (extractionStatus)
          extractionStatus.textContent = "Generating embedding vector...";
        console.log(
          "[Recipe AI] Requesting embedding from background script..."
        );

        const textToEmbed = [
          recipeData.title,
          recipeData.description,
          ...(recipeData.tags || []),
          ...(recipeData.ingredients?.map((i: any) => i.item) || []),
        ].join(", ");

        const embeddingResult: {
          success: boolean;
          embedding?: number[];
          error?: string;
        } = await chrome.runtime.sendMessage({
          type: "GENERATE_EMBEDDING",
          text: textToEmbed,
        });

        if (embeddingResult.success && embeddingResult.embedding) {
          console.log(
            `[Recipe AI] Embedding generated (${embeddingResult.embedding.length} dims).`
          );
          recipeData.embedding = embeddingResult.embedding;
        } else {
          console.warn(
            "[Recipe AI] Embedding failed, saving without vector:",
            embeddingResult.error
          );
        }

        // Save to IndexedDB (always local, no server required)
        if (extractionStatus)
          extractionStatus.textContent = "Saving to local database...";
        console.log("[Recipe AI] Saving recipe to IndexedDB...");
        await saveRecipeLocally(recipeData);
        console.log("[Recipe AI] Saved to IndexedDB successfully.");

        if (extractionStatus)
          extractionStatus.textContent = "Recipe saved! Open Pantry to view.";
      }

      // ------------- Setup logic -------------
      const finishBtn = document.getElementById("finish-setup-btn");
      const fetchModelsBtn = document.getElementById("fetch-models-btn");
      const providerSelect = document.getElementById(
        "provider-select"
      ) as HTMLSelectElement;
      const modelSelect = document.getElementById(
        "model-select"
      ) as HTMLSelectElement;
      const modelStatus = document.getElementById("model-status");
      const settingsApiKeyInput = document.getElementById(
        "api-key"
      ) as HTMLInputElement;
      const encryptionPasswordInput = document.getElementById(
        "encryption-password"
      ) as HTMLInputElement;

      fetchModelsBtn?.addEventListener("click", async () => {
        const apiKey = settingsApiKeyInput?.value;
        const provider = providerSelect.value;
        if (!apiKey) {
          if (modelStatus)
            modelStatus.textContent = "Please enter an API Key first.";
          return;
        }

        if (modelStatus)
          modelStatus.textContent = `Fetching available ${provider} models...`;
        console.log(`[Recipe AI] Fetching models from ${provider} API...`);
        if (fetchModelsBtn) {
          (fetchModelsBtn as HTMLButtonElement).disabled = true;
          (fetchModelsBtn as HTMLButtonElement).textContent = "Loading...";
        }

        modelSelect.innerHTML = "";
        modelSelect.disabled = true;

        try {
          let availableModels: {
            id: string;
            name: string;
            totalCost: number;
          }[] = [];

          if (provider === "anthropic") {
            const response = await fetch(
              "https://api.anthropic.com/v1/models",
              {
                method: "GET",
                headers: {
                  "x-api-key": apiKey,
                  "anthropic-version": "2023-06-01",
                  "anthropic-dangerous-direct-browser-access": "true",
                },
              }
            );
            if (!response.ok) throw new Error(await response.text());
            const data = await response.json();
            availableModels = data.data.map((m: any) => ({
              id: m.id,
              name: m.display_name || m.id,
              totalCost: 0,
            }));
          } else if (provider === "openrouter") {
            const response = await fetch(
              "https://openrouter.ai/api/v1/models",
              {
                headers: { Authorization: `Bearer ${apiKey}` },
              }
            );
            if (!response.ok) throw new Error(await response.text());
            const data = await response.json();

            const weakKeywords = [
              "tiny",
              "-1b",
              "-3b",
              "gpt-2",
              "gpt-j",
              "rwkv",
              "gemma-2b",
              "llama-3.2-1b",
              "qwen-1.5b",
              "gemma-2-2b",
              "yi-6b",
              "-8b",
            ];
            let filteredOpenRouter = data.data.filter((m: any) => {
              const idLower = m.id.toLowerCase();
              return (
                !weakKeywords.some((keyword) => idLower.includes(keyword)) &&
                (m.context_length || 0) >= 8000
              );
            });

            availableModels = filteredOpenRouter.map((m: any) => {
              const inPrice = Number(m.pricing?.prompt) * 1000000 || 0;
              const outPrice = Number(m.pricing?.completion) * 1000000 || 0;
              let name = m.name || m.id;
              if (inPrice > 0 || outPrice > 0)
                name += ` ($${inPrice.toFixed(2)}/$${outPrice.toFixed(
                  2
                )} per 1M)`;
              else name += ` (Free)`;
              return { id: m.id, name, totalCost: inPrice + outPrice };
            });
            availableModels.sort((a, b) => a.totalCost - b.totalCost);
          }

          if (availableModels.length === 0) {
            if (modelStatus)
              modelStatus.textContent = "No models found for this key.";
            return;
          }

          availableModels.forEach((m) => {
            const option = document.createElement("option");
            option.value = m.id;
            option.textContent = m.name;
            modelSelect.appendChild(option);
          });

          modelSelect.disabled = false;
          if (modelStatus)
            modelStatus.textContent = "Models loaded successfully!";
          if (fetchModelsBtn) {
            (fetchModelsBtn as HTMLButtonElement).disabled = false;
            fetchModelsBtn.textContent = "Fetch Models";
          }
        } catch (error: any) {
          console.error("Failed to fetch models:", error);
          if (modelStatus) modelStatus.textContent = "Failed to fetch models.";
          const option = document.createElement("option");
          option.value = "";
          option.textContent = "Error fetching models";
          modelSelect.appendChild(option);
          if (fetchModelsBtn) {
            (fetchModelsBtn as HTMLButtonElement).disabled = false;
            fetchModelsBtn.textContent = "Fetch Models";
          }
        }
      });

      finishBtn?.addEventListener("click", async () => {
        const password = encryptionPasswordInput.value;
        const apiKey = settingsApiKeyInput.value;
        const modelSelection = modelSelect.value;
        const providerSelection = providerSelect.value;

        if (!apiKey) {
          if (modelStatus) {
            modelStatus.innerHTML =
              "<span style='color:red'>Please enter an API Key.</span>";
          }
          return;
        }

        if (
          typeof chrome !== "undefined" &&
          chrome.storage &&
          chrome.storage.local
        ) {
          const storageData: Record<string, any> = {
            setupComplete: true,
            llmModel: modelSelection,
            llmProvider: providerSelection,
          };

          if (apiKey) {
            if (password) {
              try {
                const encryptedApiKey = await encryptData(apiKey, password);
                storageData.encryptedApiKey = encryptedApiKey;
                await chrome.storage.local.remove(["plaintextApiKey"]);
              } catch (err) {
                console.error("Encryption failed:", err);
                if (modelStatus) modelStatus.textContent = "Encryption failed.";
                return;
              }
            } else {
              storageData.plaintextApiKey = apiKey;
              await chrome.storage.local.remove(["encryptedApiKey"]);
            }
          }

          await chrome.storage.local.set(storageData);
          showMain(); // Return to main UI
        }
      });
    </script>
  </body>
</html>
