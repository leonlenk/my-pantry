---
---

<main class="popup-container" id="main-view">
    <header>
        <div
            style="display: flex; justify-content: space-between; align-items: start;"
        >
            <div>
                <h1>Recipe AI</h1>
                <p>Your intelligent culinary assistant</p>
            </div>
            <button
                id="settings-btn"
                class="icon-button"
                aria-label="Settings"
                title="Extension Settings"
            >
                ⚙️
            </button>
        </div>
    </header>

    <section class="action-card card">
        <h3>Current Page</h3>
        <p>Found a recipe on this page?</p>
        <button class="primary" id="extract-btn">Extract & Add to Pantry</button
        >
        <div id="password-container" class="hidden mt">
            <input
                type="password"
                id="popup-password"
                placeholder="Enter your master password"
            />
            <button class="primary mt" id="confirm-extract-btn"
                >Confirm Extraction</button
            >
            <p id="extraction-status" class="status-msg mt"></p>
        </div>
        <button class="btn mt" id="open-pantry-btn" style="width: 100%;">
            Open My Pantry
        </button>
    </section>

    <section class="chat-interface card mt">
        <h3>Substitution Agent</h3>
        <div class="chat-history" id="chat-history">
            <p class="placeholder-text">
                Ask me for substitutions or dietary modifications...
            </p>
        </div>
        <div class="chat-input-wrapper">
            <input
                type="text"
                id="chat-input"
                placeholder="e.g. Can I use yogurt instead of sour cream?"
            />
            <button id="send-btn">Send</button>
        </div>
    </section>
</main>
